# normalize text files
* text=auto

# common source files always LF
*.js   text eol=lf
*.mjs  text eol=lf
*.ts   text eol=lf
*.tsx  text eol=lf
*.json text eol=lf
*.md   text eol=lf
*.yml  text eol=lf
*.yaml text eol=lf
*.sh   text eol=lf

# windows scripts CRLF
*.ps1  text eol=crlf
*.bat  text eol=crlf
*.cmd  text eol=crlf

# binaries
*.png  binary
*.jpg  binary
*.jpeg binary
*.gif  binary
*.webp binary
*.pdf  binary
*.zip  binary
*.7z   binary
